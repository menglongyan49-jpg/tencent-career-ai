# 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# 大模型 API 配置 (选择其一)
# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic Claude (推荐)
ANTHROPIC_API_KEY=sk-ant-xxx

# 模型选择
LLM_PROVIDER=anthropic  # openai / anthropic / local
LLM_MODEL=claude-3-sonnet-20240229

# 向量数据库
CHROMA_PERSIST_DIR=./data/chroma

# 应用配置
APP_TITLE=未来鹅
APP_DEBUG=true